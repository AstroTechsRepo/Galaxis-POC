# ============================================================
# Galaxis POC — Inventory Ansible (exemple)
# Copier en `inventory` (jamais commité) et adapter.
# ============================================================

[galaxis_vm]
# Remplacer <vm-ip-ou-fqdn> et user (le sudoer qui peut lancer docker)
vm-galaxis ansible_host=<vm-ip-ou-fqdn> ansible_user=<user> ansible_ssh_private_key_file=~/.ssh/id_ed25519

[galaxis_vm:vars]
# Chemin du projet sur la VM
galaxis_app_dir=/opt/galaxis
# Référence du dépôt à cloner sur la VM
galaxis_git_repo=https://github.com/<org>/Galaxis-POC.git
galaxis_git_branch=main
