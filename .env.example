# ============================================================
# Galaxis POC — Variables d'environnement racine
# Copier ce fichier en .env (jamais commité) et adapter
# ============================================================

# ---- Identité projet
COMPOSE_PROJECT_NAME=galaxis

# ---- Point d'entrée public (vu depuis le tunnel SSH)
PUBLIC_ORIGIN=http://localhost:8080
PUBLIC_HOST=localhost:8080
PUBLIC_SCHEME=http

# ---- Keycloak admin
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-deploy
KC_DB_PASSWORD=change-me-iam-db

# ---- Keycloak realm
KC_REALM=galaxis
KC_CLIENT_ID=galaxis-portal
KC_BASE_INTERNAL=http://keycloak:8080/iam
KC_BASE_PUBLIC=http://localhost:8080/iam

# ---- Backend Laravel
APP_DB_PASSWORD=change-me-app-db
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_ENV=local
APP_DEBUG=true

# ---- Redis
REDIS_PASSWORD=change-me-redis

# ---- Vaultwarden
VAULTWARDEN_ADMIN_TOKEN=change-me-long-random-token-here
VAULTWARDEN_SIGNUPS_ALLOWED=false

# ---- Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-admin
NEXTCLOUD_DB_PASSWORD=change-me-nextcloud-db

# ---- Users de démo (créés par configure-keycloak.sh)
DEMO_USER_LUCAS_PASSWORD=demo
DEMO_USER_ADMIN_PASSWORD=demo
