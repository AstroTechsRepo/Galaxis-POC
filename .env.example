# ============================================================
# Galaxis POC v1.1 — Variables d'environnement racine
# Copier ce fichier en .env (jamais commité) et adapter
# ============================================================

# ---- Identité projet (compose)
COMPOSE_PROJECT_NAME=galaxis

# ============================================================
# Tier IAM — Keycloak
# ============================================================
KC_ADMIN=admin
KC_ADMIN_PASSWORD=change-me-keycloak-admin
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change-me-keycloak-db
KC_REALM=galaxis
KC_CLIENT_ID=galaxis-portal
KC_BASE_PUBLIC=http://localhost:8080

# ============================================================
# Tier APP — Laravel + React
# ============================================================
# Backend Laravel
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_URL=http://localhost:9080

APP_DB_USERNAME=galaxis
APP_DB_PASSWORD=change-me-app-db

REDIS_PASSWORD=change-me-redis

# Frontend Vite (figés au build time, injectés via build args dans le Dockerfile)
VITE_KC_URL=http://localhost:8080
VITE_API_URL=/api

# ============================================================
# Tier SERVICES — Vaultwarden + Nextcloud
# ============================================================
VAULTWARDEN_ADMIN_TOKEN=change-me-long-random-token-here

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me-nextcloud-admin
NEXTCLOUD_DB_USERNAME=nextcloud
NEXTCLOUD_DB_PASSWORD=change-me-nextcloud-db

# ============================================================
# Démo (utilisé par configure-keycloak.sh + DemoSeeder)
# ============================================================
# Mot de passe partagé pour TOUS les comptes Atelier Marchand
# (marc, sophie, julien, chloe, admin, lucas-test, admin-test)
# ⚠ POC démo uniquement — jamais une pratique de prod
DEMO_PASSWORD=Demo2026!
