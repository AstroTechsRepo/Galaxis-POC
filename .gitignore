# ============================================================
# Galaxis POC — .gitignore
# Multi-stack : PHP/Laravel, Node/React, Docker, Ansible
# ============================================================

# ---- Secrets et environnements
.env
.env.local
.env.*.local
**/.env
**/.env.local
!.env.example
!**/.env.example
*.pem
*.key
*.crt
secrets/
infrastructure/ansible/vault_pass*
infrastructure/ansible/group_vars/*/vault.yml

# ---- PHP / Laravel
/backend/vendor/
/backend/composer.phar
/backend/.phpunit.result.cache
/backend/.phpunit.cache/
/backend/storage/app/*
!/backend/storage/app/.gitkeep
/backend/storage/framework/cache/data/*
!/backend/storage/framework/cache/data/.gitkeep
/backend/storage/framework/sessions/*
!/backend/storage/framework/sessions/.gitkeep
/backend/storage/framework/views/*
!/backend/storage/framework/views/.gitkeep
/backend/storage/logs/*
!/backend/storage/logs/.gitkeep
/backend/bootstrap/cache/*
!/backend/bootstrap/cache/.gitkeep
/backend/public/storage
/backend/public/hot
/backend/.phpactor.json

# ---- Node / React / Vite
/frontend/node_modules/
/frontend/dist/
/frontend/build/
/frontend/.vite/
/frontend/coverage/
/frontend/.eslintcache
/frontend/.parcel-cache/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Docker volumes
docker-volumes/
*.sqlite
*.sqlite-journal

# ---- IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Ansible
*.retry
infrastructure/ansible/.vault_pass
infrastructure/ansible/collections/
infrastructure/ansible/roles/external/

# ---- Test / Coverage
coverage/
.nyc_output/
*.lcov
htmlcov/
.coverage
.tox/

# ---- Build artefacts
dist/
build/
*.tgz
*.tar.gz

# ---- Logs
*.log
logs/

# ---- Generated documentation outputs
docs/documentations/*.pdf
docs/documentations/build/
