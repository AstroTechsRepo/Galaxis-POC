# ============================================================
# Galaxis POC v1.2 — Frontend Vite
# ============================================================
# Toutes les variables sont figées AU BUILD TIME et inlinées dans le
# bundle JS. Pour changer d'environnement, il faut re-builder le front
# (cf. 'docker compose build frontend-builder').
#
# En démo, la commande SSH forward les ports loopback :
# 8080/9080/10180/11180 — ces valeurs marchent partout.
# ============================================================

# URL absolue de Keycloak (vu depuis le navigateur du laptop)
VITE_KC_URL=http://localhost:8080

# URL de l'API Laravel. Vide ou /api = chemin relatif (recommandé,
# pas de CORS preflight). Mettre une URL absolue uniquement si front
# et back sont sur des origins différents.
VITE_API_URL=/api

# Realm + client OIDC
VITE_KC_REALM=galaxis
VITE_KC_CLIENT_ID=galaxis-portal
